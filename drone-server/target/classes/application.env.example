# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JWT配置
JWT_ADMIN_SECRET_KEY=your_admin_secret_key_here_please_change_in_production
JWT_USER_SECRET_KEY=your_user_secret_key_here_please_change_in_production

# 视频上传路径配置
VIDEO_UPLOAD_PATH=/tmp/videos
VIDEO_CHUNK_PATH=/tmp/chunks

# 阿里云OSS配置（如果使用）
ALIYUN_OSS_ENDPOINT=your_oss_endpoint
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET_NAME=your_bucket_name
